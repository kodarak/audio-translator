# Copy to .env and fill in values.

# Path to Vosk Korean model directory, relative to project root (when not frozen).
# Example: models/vosk-model-small-ko-0.22
KOREAN_MODEL_PATH=

# Optional: DeepL API for translation backend
DEEPL_API_KEY=

# Optional: Hugging Face cache (development). Default uses %USERPROFILE%\.cache\huggingface\hub
# HUGGINGFACE_HUB_CACHE=
# HF_HOME=
